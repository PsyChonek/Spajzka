PORT=3001
API_URL=http://api:3000
# Public URL of the MCP endpoint (e.g. https://spajzka.vazac.dev/mcp).
# Used for OAuth resource metadata and WWW-Authenticate header.
MCP_PUBLIC_URL=https://spajzka.vazac.dev/mcp
MCP_RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=info
# Must match JWT_SECRET in the API container — used to verify OAuth access tokens.
JWT_SECRET=your-secret-key-change-in-production
