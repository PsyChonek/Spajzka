# Development Dockerfile with hot-reload. Build context is the repo root so
# ../shared/units TS sources are visible to ts-node and nodemon.

FROM node:20-alpine

WORKDIR /app

RUN apk add --no-cache tini

COPY api/package*.json ./api/

RUN cd api && npm install

COPY api/nodemon.json ./api/
COPY api/tsconfig.json ./api/
COPY api/src ./api/src
COPY shared ./shared

WORKDIR /app/api

EXPOSE 3000

ENTRYPOINT ["/sbin/tini", "--"]

CMD ["npm", "run", "dev"]
